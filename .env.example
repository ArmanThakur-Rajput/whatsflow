PORT=5000
MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=https://admin.yourcompany.com,https://yourcompany.com
NODE_ENV=development
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Business timezone used for all "today"/day-boundary calculations.
APP_TIMEZONE=Asia/Kolkata

# Firebase Admin service account JSON (entire JSON on a single line).
# NEVER commit the actual value — set it in your host's environment.
FIREBASE_SERVICE_ACCOUNT=